# --- See README

[global]
# Usefull when regret typing a modifier key, just hold it a little longer and nothing will by typed.
overload_tap_timeout = 300

[main]
# Capslock is used by XCompose to input frequently used unicode characters.
capslock = overload(control, capslock)
enter = overload(control, enter)
f = overload(nav, f)
; = overload(symbols, ;)
' = overload(media, ')
[ = -

# --- Layers ---

[nav]
# Top row
u = tab
i = esc
o = backspace
p = macro(C-S-v)
[ = +
# Home row
h = left
j = down
k = up
l = right
; = ~
' = `
d = layer(nav2)
# Bottom row
n = enter
, = [
. = ]
/ = \

[nav2]
# Top row
u = capslock
i = f2
o = delete
p = macro(C-S-tab)
# Home row
h = home
j = pagedown
k = pageup
l = end
# Bottom row
n = macro(C-tab)

[symbols]
# Top row
q = !
w = @
e = #
r = $
t = %
# Home row
capslock = ^
a = (
s = )
d = {
f = }
g = =
# Bottom row
v = |
b = &

[media]
s = previoussong
d = volumeup
f = volumedown
g = nextsong
space = playpause
