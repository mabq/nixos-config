# vim: filetype=sh

# --- General options ---

# Expansion and globing section
setopt NO_EXTENDED_GLOB # Do not treat the `#', `~' and `^' characters as part of patterns for filename generation, etc.

# Input/output section
setopt NO_CORRECT           # Try to correct the spelling of commands.
setopt NO_FLOW_CONTROL      # Disable pause/resume output (Ctrl-s/Ctrl-q)
setopt INTERACTIVE_COMMENTS # Allow comments even in interactive shells

# Zle (Zsh Line Editor)
setopt NO_BEEP # Don't beep on error

# --- General keybinds ---

bindkey -v                           # Use vi mode instead of emacs (default)
bindkey '^[[1;5C' forward-word       # Ctrl+Right
bindkey '^[[1;5D' backward-word      # Ctrl+Left
bindkey '^H' backward-kill-word      # Ctrl+Backspace
bindkey '^[[3;5~' backward-kill-word # Ctrl+Backspace alternative sequence
bindkey '^?' backward-delete-char    # Bug fix (https://github.com/spaceship-prompt/spaceship-prompt/issues/91#issuecomment-327996599)
# bindkey '^[[H' beginning-of-line   # Home
# bindkey '^[[F' end-of-line         # End

# --- Out keybinds ---

bindkey -s '^s' "tmux-sessionizer\n" # Ctrol+s

# --- History configuration ---

# History file
# Do not export these!, otherwise other shells (bash) will try to use same HISTFILE.
HISTFILE=${HOME}/.local/share/zsh/zsh_history    # move the file away from home
[[ -d ${HISTFILE:h} ]] || mkdir -p ${HISTFILE:h} # ensure the directory exists
SAVEHIST=10000                                   # lines to save to history file
HISTSIZE="${SAVEHIST}"                           # lines to keep in memory

# History options
setopt NO_HIST_BEEP
setopt HIST_FCNTL_LOCK
setopt EXTENDED_HISTORY       # save timestamp and command duration
setopt HIST_EXPIRE_DUPS_FIRST # lose oldest duplicates first
setopt HIST_IGNORE_ALL_DUPS   # ignore all duplicate commands, regardless of whether they are consecutive or not
setopt HIST_IGNORE_SPACE      # any command that starts with a space character will not be recorded in the command history --- useful to prevent accidentally storing sensitive or irrelevant commands in your history
setopt HIST_REDUCE_BLANKS     # remove extra blanks from each command line being added to history
setopt INC_APPEND_HISTORY     # write each new command to the history file as soon as it's entered, rather than waiting until the end of the session
setopt SHARE_HISTORY          # share history file accross all zsh instances

# --- Autocompletion ---

# Load completion
# NixOS automatically generates the `/etc/zshenv` file, it sets the `fpath` variable that instructs zsh how to find installed completions.
autoload -Uz compinit                                     # prepare to load compinit, don't use aliases and use zsh-style zstyle ":completion:*" menu select # use select completion style
zstyle ':completion:*' menu select                        # use keys to navigate
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' # make completion case-insensitive
ZCOMPFILE=${HOME}/.cache/zsh/zcompdump-${ZSH_VERSION}     # file location (clean home)
[[ -d ${ZCOMPFILE:h} ]] || mkdir -p ${ZCOMPFILE:h}        # ensure the directory exists
compinit -d "$ZCOMPFILE"                                  # initialize the completion module

setopt NO_MENU_COMPLETE
setopt ALWAYS_TO_END
setopt COMPLETE_IN_WORD

# --- Source plugins ---

sourceZshPlugins() {
  # These packages do not provide executables, we must source the files from the current home-manager version.
  currentHomePath=""$HOME/.local/state/home-manager/gcroots/current-home/home-path""

  if [[ -f $currentHomePath/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source $currentHomePath/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  fi

  if [[ -f $currentHomePath/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source $currentHomePath/share/zsh-autosuggestions/zsh-autosuggestions.zsh
  fi

  if [[ -f $currentHomePath/share/zsh-history-substring-search/zsh-history-substring-search.zsh ]]; then
    source $currentHomePath/share/zsh-history-substring-search/zsh-history-substring-search.zsh
    bindkey '^[[A' history-substring-search-up   # up arrow (atuin is launched with `--disable-up-arrow`)
    bindkey '^[[B' history-substring-search-down # donw arrow
    HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_FOUND=''
    HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_NOT_FOUND=''
  fi
}
sourceZshPlugins

