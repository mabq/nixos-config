#!/usr/bin/env bash

themes_path="$NC_REPO_PATH/themes/"

selected_theme_path=$(fd --hidden --no-ignore --exact-depth 1 --type directory . $themes_path | fzf)
if [[ -z $selected_theme_path ]]; then
  exit 0
fi

selected_theme_name=$(basename "$selected_theme_path")
nixos-theme-set-templates "$selected_theme_name"

# Create the session (if necessary) in detached mode
link_path="$NC_CURRENT_THEME_PATH"
rm -rf "$link_path"
ln -s "$selected_theme_path" "$link_path"
